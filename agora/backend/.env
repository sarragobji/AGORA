# L'Agora — Variables d'environnement Backend
# Copiez ce fichier en .env et adaptez les valeurs

SECRET_KEY=your-very-long-secret-key-here-change-in-production

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données MySQL
DB_NAME=agora_db1
DB_USER=root
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=3306

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
